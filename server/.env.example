# Basic configuration
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# SQLite data directory (databases created automatically)
CHURCH_DATA_DIR=./data

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_change_this_in_production
JWT_EXPIRE=30d

# OTC Configuration
OTC_EXPIRE_MINUTES=10
OTC_RESEND_COOLDOWN_SECONDS=60

# Email Configuration
EMAIL_FROM=hello@letmypeoplegrow.com.au
EMAIL_FROM_NAME="Let My People Grow"
EMAIL_DOMAIN=letmypeoplegrow.com.au
CHURCH_NAME="Let My People Grow"

# Brevo API key (required for email authentication)
BREVO_API_KEY=your_brevo_api_key_here

# SMS Configuration (optional - for SMS-based authentication)
CRAZYTEL_API_KEY=your_crazytel_api_key_here
CRAZYTEL_FROM_NUMBER=your_crazytel_from_number_here

# Elvanto Integration Configuration (optional)
# Get these from https://www.elvanto.com/api/getting-started/#oauth
ELVANTO_CLIENT_ID=your_elvanto_client_id_here
ELVANTO_CLIENT_SECRET=your_elvanto_client_secret_here
ELVANTO_REDIRECT_URI=https://localhost/api/integrations/elvanto/callback
